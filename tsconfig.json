{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"noUncheckedIndexedAccess": true,
		"types": ["node", "vitest/globals"]
	},
	"include": ["src/**/*", "tests/**/*", "vitest.config.ts"],
	"exclude": ["dist", "node_modules"]
}
